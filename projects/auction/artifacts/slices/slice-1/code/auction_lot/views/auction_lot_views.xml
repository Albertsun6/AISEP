<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════ -->
    <!--  auction.lot — Form View                     -->
    <!-- ════════════════════════════════════════════ -->
    <record id="view_auction_lot_form" model="ir.ui.view">
        <field name="name">auction.lot.form</field>
        <field name="model">auction.lot</field>
        <field name="arch" type="xml">
            <form string="拍品">
                <!-- Header: 状态栏和按钮 -->
                <header>
                    <button name="action_approve" type="object"
                            string="审核通过" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_withdraw" type="object"
                            string="撤回"
                            invisible="state != 'approved'"/>
                    <button name="action_reset_draft" type="object"
                            string="重置草稿"
                            invisible="state != 'withdrawn'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,approved,assigned,sold"/>
                </header>

                <!-- Sheet: 主数据区 -->
                <sheet>
                    <group>
                        <group string="基本信息">
                            <field name="name"/>
                            <field name="category_id"/>
                            <field name="consignor_id"/>
                        </group>
                        <group string="系统信息">
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                            <field name="currency_id"
                                   groups="base.group_multi_currency"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- 定价信息 -->
                        <page string="定价信息" name="pricing">
                            <group>
                                <group string="起拍与底价">
                                    <field name="is_no_reserve"/>
                                    <field name="starting_price"/>
                                    <field name="reserve_price"
                                           invisible="is_no_reserve"
                                           groups="auction_lot.group_auction_manager"/>
                                </group>
                                <group string="估价区间">
                                    <field name="low_estimate"/>
                                    <field name="high_estimate"/>
                                </group>
                            </group>
                        </page>

                        <!-- 图片 -->
                        <page string="图片" name="images">
                            <field name="image_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="image" widget="image"
                                           options="{'size': [100, 100]}"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>

                        <!-- 描述 -->
                        <page string="描述" name="description">
                            <field name="description" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>

                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════ -->
    <!--  auction.lot — Tree View                     -->
    <!-- ════════════════════════════════════════════ -->
    <record id="view_auction_lot_tree" model="ir.ui.view">
        <field name="name">auction.lot.tree</field>
        <field name="model">auction.lot</field>
        <field name="arch" type="xml">
            <tree string="拍品列表">
                <field name="name"/>
                <field name="category_id"/>
                <field name="consignor_id" optional="show"/>
                <field name="starting_price"/>
                <field name="reserve_price"
                       groups="auction_lot.group_auction_manager"
                       optional="hide"/>
                <field name="is_no_reserve"/>
                <field name="image_count" string="图片"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'sold'"
                       decoration-warning="state == 'approved'"
                       decoration-danger="state == 'unsold'"/>
            </tree>
        </field>
    </record>

    <!-- ════════════════════════════════════════════ -->
    <!--  auction.lot — Search View                   -->
    <!-- ════════════════════════════════════════════ -->
    <record id="view_auction_lot_search" model="ir.ui.view">
        <field name="name">auction.lot.search</field>
        <field name="model">auction.lot</field>
        <field name="arch" type="xml">
            <search string="搜索拍品">
                <field name="name" string="名称/描述"
                       filter_domain="['|',('name','ilike',self),('description','ilike',self)]"/>
                <field name="category_id"/>
                <field name="consignor_id"/>
                <separator/>
                <filter name="filter_draft" string="草稿"
                        domain="[('state','=','draft')]"/>
                <filter name="filter_approved" string="已审核"
                        domain="[('state','=','approved')]"/>
                <filter name="filter_assigned" string="已编排"
                        domain="[('state','=','assigned')]"/>
                <filter name="filter_sold" string="已成交"
                        domain="[('state','=','sold')]"/>
                <filter name="filter_unsold" string="流拍"
                        domain="[('state','=','unsold')]"/>
                <separator/>
                <filter name="filter_no_reserve" string="无底价"
                        domain="[('is_no_reserve','=',True)]"/>
                <separator/>
                <group expand="0" string="分组">
                    <filter name="group_category" string="按分类"
                            context="{'group_by': 'category_id'}"/>
                    <filter name="group_state" string="按状态"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_consignor" string="按委托方"
                            context="{'group_by': 'consignor_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ════════════════════════════════════════════ -->
    <!--  auction.lot — Kanban View                   -->
    <!-- ════════════════════════════════════════════ -->
    <record id="view_auction_lot_kanban" model="ir.ui.view">
        <field name="name">auction.lot.kanban</field>
        <field name="model">auction.lot</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="category_id"/>
                <field name="starting_price"/>
                <field name="state"/>
                <field name="image_count"/>
                <field name="is_no_reserve"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span><field name="category_id"/></span>
                                        <span class="ms-2">
                                            <field name="starting_price" widget="monetary"/>
                                        </span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <span t-if="record.is_no_reserve.raw_value"
                                              class="badge text-bg-danger">无底价</span>
                                        <span class="badge text-bg-secondary ms-1">
                                            <field name="image_count"/> 图
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>
