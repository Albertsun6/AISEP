<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════ -->
    <!--  Security Groups                             -->
    <!-- ════════════════════════════════════════════ -->
    <record id="group_auction_user" model="res.groups">
        <field name="name">拍卖运营</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="base.module_category_sales"/>
    </record>

    <record id="group_auction_manager" model="res.groups">
        <field name="name">拍卖经理</field>
        <field name="implied_ids" eval="[(4, ref('group_auction_user'))]"/>
        <field name="category_id" ref="base.module_category_sales"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- ════════════════════════════════════════════ -->
    <!--  Record Rules                                -->
    <!-- ════════════════════════════════════════════ -->
    <record id="rule_lot_company" model="ir.rule">
        <field name="name">拍品: 多公司隔离</field>
        <field name="model_id" ref="model_auction_lot"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_auction_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
