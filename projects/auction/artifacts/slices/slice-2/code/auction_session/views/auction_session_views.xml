<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════ -->
    <!--  auction.session — Form                      -->
    <!-- ════════════════════════════════════════════ -->
    <record id="view_auction_session_form" model="ir.ui.view">
        <field name="name">auction.session.form</field>
        <field name="model">auction.session</field>
        <field name="arch" type="xml">
            <form string="拍卖会">
                <header>
                    <button name="action_publish" string="发布"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_start" string="开始拍卖"
                            type="object" class="btn-primary"
                            invisible="state != 'published'"/>
                    <button name="action_close" string="结束拍卖"
                            type="object"
                            invisible="state != 'ongoing'"/>
                    <button name="action_cancel" string="取消"
                            type="object"
                            invisible="state not in ('draft', 'published')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,published,ongoing,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="场次名称"/>
                        </h1>
                    </div>
                    <group>
                        <group string="基本信息">
                            <field name="start_time"/>
                            <field name="end_time"/>
                            <field name="lot_count"/>
                        </group>
                        <group string="系统信息">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="拍卖规则" name="rules">
                            <group>
                                <group string="竞价设置">
                                    <field name="default_increment"/>
                                    <field name="countdown_seconds"/>
                                    <field name="extension_seconds"/>
                                </group>
                                <group string="成交设置">
                                    <field name="conditional_sale_pct"/>
                                </group>
                            </group>
                        </page>
                        <page string="拍品编排" name="lots">
                            <field name="session_lot_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="lot_id"/>
                                    <field name="lot_state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="描述" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════ -->
    <!--  auction.session — Tree                      -->
    <!-- ════════════════════════════════════════════ -->
    <record id="view_auction_session_tree" model="ir.ui.view">
        <field name="name">auction.session.tree</field>
        <field name="model">auction.session</field>
        <field name="arch" type="xml">
            <tree string="拍卖会列表"
                  decoration-success="state == 'closed'"
                  decoration-warning="state == 'ongoing'"
                  decoration-danger="state == 'cancelled'">
                <field name="name"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="lot_count"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'closed'"
                       decoration-warning="state == 'ongoing'"
                       decoration-danger="state == 'cancelled'"
                       decoration-info="state == 'published'"/>
            </tree>
        </field>
    </record>

    <!-- ════════════════════════════════════════════ -->
    <!--  auction.session — Search                    -->
    <!-- ════════════════════════════════════════════ -->
    <record id="view_auction_session_search" model="ir.ui.view">
        <field name="name">auction.session.search</field>
        <field name="model">auction.session</field>
        <field name="arch" type="xml">
            <search string="搜索拍卖会">
                <field name="name"/>
                <separator/>
                <filter name="filter_draft" string="草稿"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_published" string="已发布"
                        domain="[('state', '=', 'published')]"/>
                <filter name="filter_ongoing" string="进行中"
                        domain="[('state', '=', 'ongoing')]"/>
                <filter name="filter_closed" string="已结束"
                        domain="[('state', '=', 'closed')]"/>
                <separator/>
                <group expand="0" string="分组">
                    <filter name="group_state" string="按状态"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ════════════════════════════════════════════ -->
    <!--  auction.session — Kanban                    -->
    <!-- ════════════════════════════════════════════ -->
    <record id="view_auction_session_kanban" model="ir.ui.view">
        <field name="name">auction.session.kanban</field>
        <field name="model">auction.session</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="start_time"/>
                <field name="lot_count"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <strong><field name="name"/></strong>
                                <div class="text-muted">
                                    <field name="start_time"/>
                                </div>
                                <div>
                                    拍品: <field name="lot_count"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>
