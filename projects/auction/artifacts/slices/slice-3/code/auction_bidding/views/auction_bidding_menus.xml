<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════ -->
    <!--  Actions                                     -->
    <!-- ════════════════════════════════════════════ -->
    <record id="action_auction_bidding_round" model="ir.actions.act_window">
        <field name="name">竞价轮次</field>
        <field name="res_model">auction.bidding.round</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                暂无竞价轮次
            </p>
            <p>
                开始拍卖后，系统将自动为每件拍品创建竞价轮次。
            </p>
        </field>
    </record>

    <record id="action_auction_bid" model="ir.actions.act_window">
        <field name="name">出价记录</field>
        <field name="res_model">auction.bid</field>
        <field name="view_mode">tree</field>
    </record>

    <!-- ════════════════════════════════════════════ -->
    <!--  Menus — 挂载到 auction_lot 顶级菜单下        -->
    <!-- ════════════════════════════════════════════ -->

    <menuitem id="menu_auction_bidding"
              name="竞价管理"
              parent="auction_lot.menu_auction_root"
              sequence="30"/>

    <menuitem id="menu_auction_bidding_rounds"
              name="竞价轮次"
              parent="menu_auction_bidding"
              action="action_auction_bidding_round"
              sequence="10"
              groups="auction_lot.group_auction_user"/>

    <menuitem id="menu_auction_bidding_history"
              name="出价记录"
              parent="menu_auction_bidding"
              action="action_auction_bid"
              sequence="20"
              groups="auction_lot.group_auction_user"/>

</odoo>
