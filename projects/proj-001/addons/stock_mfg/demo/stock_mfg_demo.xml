<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ══════════════════════════════════════════════════════════════
             演示数据：仓库 + 库位 + 初始库存
             ══════════════════════════════════════════════════════════════ -->

        <!-- 默认仓库配置（Odoo 安装 stock 模块时已自动创建 WH）
             这里仅创建额外的子库位作为演示数据 -->

        <!-- 子库位：原材料区 -->
        <record id="demo_location_raw" model="stock.location">
            <field name="name">原材料区</field>
            <field name="location_id" ref="stock.stock_location_stock"/>
            <field name="usage">internal</field>
        </record>

        <!-- 子库位：成品区 -->
        <record id="demo_location_finished" model="stock.location">
            <field name="name">成品区</field>
            <field name="location_id" ref="stock.stock_location_stock"/>
            <field name="usage">internal</field>
        </record>

        <!-- 子库位：待检区 -->
        <record id="demo_location_inspection" model="stock.location">
            <field name="name">待检区</field>
            <field name="location_id" ref="stock.stock_location_stock"/>
            <field name="usage">internal</field>
        </record>

    </data>
</odoo>
