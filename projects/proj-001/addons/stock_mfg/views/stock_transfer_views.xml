<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════
         Slice 7: 库存调拨快捷入口（US-025）
         标准 stock 模块已内置调拨功能，此处添加菜单快捷入口
         ══════════════════════════════════════════════════ -->

    <!-- 调拨操作 Action — 筛选内部调拨 -->
    <record id="action_stock_internal_transfer" model="ir.actions.act_window">
        <field name="name">库存调拨</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('picking_type_code', '=', 'internal')]</field>
        <field name="context">{'default_picking_type_id': ref('stock.picking_type_internal'),
                               'search_default_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                创建库存调拨
            </p>
            <p>将物料从一个库位调拨到另一个库位。</p>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════
         Slice 7: 盘点 / 库存调整入口（US-029, US-030）
         Standard Odoo stock 模块自带 Inventory Adjustment
         ══════════════════════════════════════════════════ -->

    <!-- 盘点 Action — 库存数量（含调整功能） -->
    <record id="action_stock_inventory_adjustment" model="ir.actions.act_window">
        <field name="name">盘点与库存调整</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">tree</field>
        <field name="domain">[('location_id.usage', '=', 'internal')]</field>
        <field name="context">{'inventory_mode': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                发起盘点
            </p>
            <p>查看并调整库存数量，录入实盘数量后系统自动计算差异。</p>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════
         菜单入口 — 在库存模块下添加
         ══════════════════════════════════════════════════ -->
    <menuitem id="menu_stock_transfer"
              name="库存调拨"
              parent="stock.menu_stock_warehouse_mgmt"
              action="action_stock_internal_transfer"
              sequence="40"/>

    <menuitem id="menu_stock_inventory"
              name="盘点与调整"
              parent="stock.menu_stock_warehouse_mgmt"
              action="action_stock_inventory_adjustment"
              sequence="50"/>

</odoo>
