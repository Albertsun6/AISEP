<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ══════════════════════════════════════════════════
             安全组定义
             ══════════════════════════════════════════════════ -->

        <!-- 模块分类 -->
        <record id="module_category_mrp_mfg" model="ir.module.category">
            <field name="name">制造管理</field>
            <field name="sequence">20</field>
        </record>

        <!-- 制造用户 -->
        <record id="group_mfg_user" model="res.groups">
            <field name="name">制造用户</field>
            <field name="category_id" ref="module_category_mrp_mfg"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- 制造经理（继承制造用户的所有权限） -->
        <record id="group_mfg_manager" model="res.groups">
            <field name="name">制造经理</field>
            <field name="category_id" ref="module_category_mrp_mfg"/>
            <field name="implied_ids" eval="[(4, ref('mrp_mfg.group_mfg_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- ══════════════════════════════════════════════════
             Record Rules — 公司级数据隔离 (P3-04)
             ══════════════════════════════════════════════════ -->

        <!-- BOM：当前公司 -->
        <record id="rule_mrp_bom_company" model="ir.rule">
            <field name="name">BOM：当前公司</field>
            <field name="model_id" ref="mrp.model_mrp_bom"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('mrp_mfg.group_mfg_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- 生产工单：当前公司 -->
        <record id="rule_mrp_production_company" model="ir.rule">
            <field name="name">生产工单：当前公司</field>
            <field name="model_id" ref="mrp.model_mrp_production"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('mrp_mfg.group_mfg_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
